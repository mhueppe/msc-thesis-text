{"latex-workshop.latex.tools": [
  {
    "name": "pdflatex",
    "command": "pdflatex",
    "args": [
      "-synctex=1",
      "-interaction=nonstopmode",
      "-file-line-error",
      "%DOC%"
    ]
  },
  {
    "name": "biber",
    "command": "biber",
    "args": [
      "%DOCFILE%"
    ]
  },
  {
    "name": "makeglossaries",
    "command": "makeglossaries",
    "args": [
      "%DOCFILE%"
    ]
  }
],
"latex-workshop.latex.recipes": [
  {
    "name": "Fast: pdflatex",
    "tools": [
      "pdflatex"
    ]
  },
  {
    "name": "Glossaries: pdflatex -> makeglossaries -> pdflatex",
    "tools": [
      "pdflatex",
      "makeglossaries",
      "pdflatex"
    ]
  },
  {
    "name": "Biber: pdflatex -> biber -> pdflatex -> pdflatex",
    "tools": [
      "pdflatex",
      "biber",
      "pdflatex",
      "pdflatex"
    ]
  },
  {
    "name": "Everything: pdflatex -> biber -> makeglossaries -> pdflatex -> pdflatex",
    "tools": [
      "pdflatex",
      "biber",
      "makeglossaries",
      "pdflatex",
      "pdflatex"
    ]
  }
]}