@Article{Kirkwood2015,
  author   = {Kirkwood, Jobie and Hargreaves, David and O’Keefe, Simon and Wilson, Julie},
  journal  = {Bioinformatics},
  title    = {Using isoelectric point to determine the {pH} for initial protein crystallization trials},
  year     = {2015},
  issn     = {1367-4803},
  month    = may,
  number   = {9},
  pages    = {1444--1451},
  volume   = {31},
  abstract = {Motivation: The identification of suitable conditions for crystallization is a rate-limiting step in protein structure determination. The pH of an experiment is an important parameter and has the potential to be used in data-mining studies to help reduce the number of crystallization trials required. However, the pH is usually recorded as that of the buffer solution, which can be highly inaccurate., Results: Here, we show that a better estimate of the true pH can be predicted by considering not only the buffer pH but also any other chemicals in the crystallization solution. We use these more accurate pH values to investigate the disputed relationship between the pI of a protein and the pH at which it crystallizes., Availability and implementation: Data used to generate models are available as Supplementary Material., Contact: julie.wilson@york.ac.uk, Supplementary information: Supplementary data are available at Bioinformatics online.},
  doi      = {10.1093/bioinformatics/btv011},
  pmcid    = {PMC4410668},
  pmid     = {25573921},
  url      = {https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4410668/},
  urldate  = {2025-08-07},
}

